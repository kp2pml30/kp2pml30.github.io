root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = tab
tab_width = 2

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[*.nix]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4
