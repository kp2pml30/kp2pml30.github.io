# Ensure consistent line endings
* text=auto eol=lf

# Binary files — no diff, no merge
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.xz binary
*.wasm binary
*.woff binary
*.woff2 binary

# Vendored trees — not counted as project code
third-party/**      linguist-vendored
**/third-party/**   linguist-vendored

# Lockfiles — generated, not project code
*.lock              linguist-generated
package-lock.json   linguist-generated
Cargo.lock          linguist-generated
flake.lock          linguist-generated

# Generated by generator/main.rb — not hand-edited
frontend/src/tree.json      linguist-generated
*.blog                      linguist-generated
