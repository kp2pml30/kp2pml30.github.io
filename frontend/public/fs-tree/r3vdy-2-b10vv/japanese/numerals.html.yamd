			#cell: さんびゃく (not さんひゃく)
		#row
			#cell: 600
			#cell: ろっぴゃく (not ろくひゃく)
		#row
			#cell: 800
			#cell: はっぴゃく (not はちひゃく)
		#row
			#cell: 1,000
			#cell: せん
