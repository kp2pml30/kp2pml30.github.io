#h1{Numbers, Counters & Time}

#h2{Basic numbers}

#bordered
	#table(header: 1)
		#row
			#cell: Number
			#cell: Sino-Japanese (漢語)
			#cell: Native Japanese (和語)
		#row
			#cell: 1
			#cell: いち
			#cell: ひとつ
		#row
			#cell: 2
			#cell: に
			#cell: ふたつ
		#row
			#cell: 3
			#cell: さん
			#cell: みっつ
		#row
			#cell: 4
			#cell: し / よん
			#cell: よっつ
		#row
			#cell: 5
			#cell: ご
			#cell: いつつ
		#row
			#cell: 6
			#cell: ろく
			#cell: むっつ
		#row
			#cell: 7
			#cell: しち / なな
			#cell: ななつ
		#row
			#cell: 8
			#cell: はち
			#cell: やっつ
		#row
			#cell: 9
			#cell: く / きゅう
			#cell: ここのつ
		#row
			#cell: 10
			#cell: じゅう
			#cell: とお

Native Japanese numbers (～つ) are used for general counting up to 10, when no specific counter applies. Above 10, always use Sino-Japanese.

#bordered
	#table(header: 1)
		#row
			#cell: Number
			#cell: Reading
		#row
			#cell: 100
			#cell: ひゃく
